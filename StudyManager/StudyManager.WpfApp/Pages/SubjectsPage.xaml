<Page x:Class="StudyManager.WpfApp.Pages.SubjectsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}">

    <Grid>
        <Border Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Предмети" Style="{StaticResource TitleText}"/>

                <ListBox x:Name="SubjectsList" Grid.Row="1" Margin="0,8,0,12"
                         DisplayMemberPath="Name"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1"
                         Padding="6"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Відкрити" Style="{StaticResource PrimaryButton}" Click="Open_Click"/>
                </StackPanel>
            </Grid>

        </Border>
    </Grid>
</Page>