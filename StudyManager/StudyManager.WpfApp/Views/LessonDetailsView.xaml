<UserControl x:Class="StudyManager.WpfApp.Views.LessonDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="12">
        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Lesson.Topic}"/>
        <TextBlock Margin="0,6,0,0" Text="{Binding Lesson.Date, StringFormat=Дата: {0}}"/>
        <TextBlock Text="{Binding Lesson.StartTime, StringFormat=Початок: {0}}"/>
        <TextBlock Text="{Binding Lesson.EndTime, StringFormat=Завершення: {0}}"/>
        <TextBlock Text="{Binding Lesson.Type, StringFormat=Тип: {0}}"/>
        <TextBlock Text="{Binding Lesson.Duration, StringFormat=Тривалість: {0}}"/>
    </StackPanel>
</UserControl>