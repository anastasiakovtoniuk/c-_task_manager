<UserControl x:Class="StudyManager.WpfApp.Views.LessonDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Border Style="{StaticResource Card}">
        <StackPanel>
            <TextBlock Text="{Binding Lesson.Topic}" Style="{StaticResource TitleText}"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding Lesson.Date, StringFormat=Дата: {0}}"/>
                <TextBlock Grid.Row="1" Text="{Binding Lesson.StartTime, StringFormat=Початок: {0}}"/>
                <TextBlock Grid.Row="2" Text="{Binding Lesson.EndTime, StringFormat=Завершення: {0}}"/>
                <TextBlock Grid.Row="3" Text="{Binding Lesson.Type, StringFormat=Тип: {0}}"/>
                <TextBlock Grid.Row="4" Text="{Binding Lesson.Duration, StringFormat=Тривалість: {0}}"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>