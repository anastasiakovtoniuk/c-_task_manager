<UserControl x:Class="StudyManager.WpfApp.Views.SubjectDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Subject.Name}"/>

        <StackPanel Grid.Row="1" Margin="0,6,0,10">
            <TextBlock Text="{Binding Subject.EctsCredits, StringFormat=ECTS: {0}}"/>
            <TextBlock Text="{Binding Subject.Domain, StringFormat=Сфера: {0}}"/>
            <TextBlock Text="{Binding Subject.TotalDuration, StringFormat=Загальна тривалість: {0}}"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <ListBox ItemsSource="{Binding Lessons}"
                     SelectedItem="{Binding SelectedLesson}"
                     DisplayMemberPath="Topic"/>

            <TextBlock Text="Немає занять для цього предмета."
           HorizontalAlignment="Center"
           VerticalAlignment="Center"
           Foreground="Gray"
           FontStyle="Italic">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasNoLessons}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <Button Grid.Row="3"
                Content="Деталі заняття"
                Command="{Binding OpenLessonCommand}"
                Width="140" Height="32"
                Margin="0,10,0,0"/>
    </Grid>
</UserControl>