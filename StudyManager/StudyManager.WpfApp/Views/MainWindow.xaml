<Window x:Class="StudyManager.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StudyManager.WpfApp.ViewModels"
        xmlns:v="clr-namespace:StudyManager.WpfApp.Views"
        Title="StudyManager" Height="520" Width="900">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <DataTemplate DataType="{x:Type vm:SubjectsListViewModel}">
            <v:SubjectsListView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SubjectDetailsViewModel}">
            <v:SubjectDetailsView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:LessonDetailsViewModel}">
            <v:LessonDetailsView/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <Button Content="← Назад"
                    Width="110"
                    Command="{Binding BackCommand}"
                    IsEnabled="{Binding CanGoBack}"/>
            <TextBlock Margin="12,0,0,0" VerticalAlignment="Center"
                       Text="Менеджер занять" FontWeight="SemiBold"/>
        </StackPanel>

        <ContentControl Content="{Binding CurrentViewModel}" Margin="10"/>
    </DockPanel>
</Window>